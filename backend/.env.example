# ============================================
# MKEKA BOT — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/mkeka_bot

# ANTHROPIC (Claude API — the brain)
ANTHROPIC_API_KEY=sk-ant-...

# APIFY (scrapers)
APIFY_API_TOKEN=apify_api_...

# BETTRACK SYNC (optional)
BETTRACK_API_URL=http://localhost:4000
BETTRACK_API_KEY=your-bettrack-key

# SERVER
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
