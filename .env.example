# ================================================================
# MKEKA BOT v3 — Environment Variables
# Data: Firecrawl → FlashScore (replaces Apify + API-Football)
# ================================================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:davyswai1995@localhost:5432/mkeka_bot

# Anthropic Claude API
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxx

# Firecrawl API — MAIN DATA SOURCE
# https://firecrawl.dev → Sign up → Get API key
# Free: 500 credits/mo | Paid: $16/mo (recommended)
FIRECRAWL_API_KEY=fc-adcbbff47f5548b4b39f197dcde1b761

# Leagues to scan daily (comma-separated)
# Options: championship, league_one, laliga, bundesliga, seriea, ligue1, epl, league_two, segunda
ACTIVE_LEAGUES=championship,league_one,laliga,bundesliga,seriea,ligue1,epl

# Minimum confidence to recommend a bet (0-100)
MIN_CONFIDENCE_TO_BET=65

# App
NEXT_PUBLIC_APP_NAME=MkekaBOT
NODE_ENV=development

# Enable cron jobs (set to 'true' in production)
RUN_CRON=false

# BetTrack integration (optional)
BETTRACK_API_URL=http://localhost:3001
BETTRACK_API_KEY=your_bettrack_key
